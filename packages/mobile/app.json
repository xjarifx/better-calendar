{
  "expo": {
    "name": "Better Calendar",
    "slug": "better-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "better-calendar",
    "splash": {
      "backgroundColor": "#0a0a0a",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bettercalendar.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.bettercalendar.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/b553bfae-29d3-4b91-86c4-18ea8b1a4cf9",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b553bfae-29d3-4b91-86c4-18ea8b1a4cf9"
      }
    }
  }
}
